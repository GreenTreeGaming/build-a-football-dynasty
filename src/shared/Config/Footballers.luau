local ids: { [string]: boolean } = {}
local positionCounts: { [string]: number } = {}

for _, footballer in ipairs(footballers) do
	assert(not ids[footballer.Id], "Duplicate footballer ID: " .. footballer.Id)
	ids[footballer.Id] = true
	positionCounts[footballer.Position] = (positionCounts[footballer.Position] or 0) + 1
	table.freeze(footballer)
end

for _, position in ipairs({
	"GK",
	"LB",
	"CB",
	"RB",
	"CDM",
	"CM",
	"CAM",
	"LW",
	"RW",
	"ST",
}) do
	assert(
		(positionCounts[position] or 0) >= 5,
		"Footballers catalog needs at least five players for position " .. position
	)
end

return table.freeze(footballers)
